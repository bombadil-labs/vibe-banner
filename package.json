{
  "name": "vibe-banner",
  "version": "0.89.0",
  "description": "Renders Claude's vibe banner from feeling-values. Loaded by the vibe-banner skill via jsDelivr; the skill passes only the values.",
  "license": "MIT",
  "private": false,
  "main": "src/vibe.js",
  "scripts": {
    "build": "esbuild src/vibe.js --minify --outfile=dist/vibe.min.js",
    "parity": "node test/parity.js && node test/builder-parity.js",
    "pin": "node scripts/pin.js",
    "scene": "node scripts/gen-scene.js",
    "sepia": "node scripts/gen-sepia.js",
    "skills": "node scripts/gen-skills.js",
    "skill": "node scripts/compose-skill.js",
    "skill:install": "node scripts/compose-skill.js sepia tidepool --install",
    "kip": "node scripts/gen-kip.js",
    "drollery": "node scripts/gen-drollery.js"
  },
  "devDependencies": {
    "esbuild": "^0.23.1"
  }
}
